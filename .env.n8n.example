# Copia este archivo a .env para docker compose
# URL publica de ngrok donde estara visible n8n (con slash final)
WEBHOOK_URL=https://TU-SUBDOMINIO.ngrok-free.app/

# URL del editor de n8n (sin slash final)
N8N_EDITOR_BASE_URL=https://TU-SUBDOMINIO.ngrok-free.app

# Como corre local para demo
N8N_HOST=localhost
N8N_PROTOCOL=http

# Genera una clave larga aleatoria para cifrar credenciales en n8n
N8N_ENCRYPTION_KEY=CAMBIA_ESTA_CLAVE_POR_UNA_LARGA_Y_UNICA

# Flask local expuesto por ngrok (endpoint de logs)
FLASK_BASE_URL=https://TU-FLASK.ngrok-free.app

# Puente Baileys para WhatsApp
# Si n8n corre en Docker y el bridge en host, usa: http://host.docker.internal:3001
BAILEYS_BRIDGE_URL=http://host.docker.internal:3001
WHATSAPP_COCINA=52XXXXXXXXXX
WHATSAPP_ADMIN=52XXXXXXXXXX
