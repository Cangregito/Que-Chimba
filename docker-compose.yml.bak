version: "3.9"

services:
  n8n:
    image: n8nio/n8n:latest
    container_name: quechimba-n8n
    restart: unless-stopped
    ports:
      - "5678:5678"
    environment:
      - TZ=America/Ciudad_Juarez
      - N8N_HOST=${N8N_HOST:-localhost}
      - N8N_PORT=5678
      - N8N_PROTOCOL=${N8N_PROTOCOL:-http}
      - N8N_EDITOR_BASE_URL=${N8N_EDITOR_BASE_URL}
      - WEBHOOK_URL=${WEBHOOK_URL}
      - N8N_BASIC_AUTH_ACTIVE=${N8N_BASIC_AUTH_ACTIVE:-true}
      - N8N_BASIC_AUTH_USER=${N8N_BASIC_AUTH_USER}
      - N8N_BASIC_AUTH_PASSWORD=${N8N_BASIC_AUTH_PASSWORD}
      - N8N_SECURE_COOKIE=${N8N_SECURE_COOKIE:-true}
      - N8N_ENCRYPTION_KEY=${N8N_ENCRYPTION_KEY}
      - FLASK_BASE_URL=${FLASK_BASE_URL}
      - BAILEYS_BRIDGE_URL=${BAILEYS_BRIDGE_URL}
      - WHATSAPP_COCINA=${WHATSAPP_COCINA}
      - WHATSAPP_ADMIN=${WHATSAPP_ADMIN}
    volumes:
      - ./n8n_data:/home/node/.n8n
